# =============================================================================
# OSS Dependency Risk Agent — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env to git.
# =============================================================================

# ── Anthropic / Claude ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=                  # Your Anthropic API key (sk-ant-...)
ANTHROPIC_MODEL=claude-sonnet-4-5     # Claude model ID to use for the agent

# ── AWS / S3 (Bronze Layer) ───────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=                  # IAM user or role access key
AWS_SECRET_ACCESS_KEY=              # IAM user or role secret key
AWS_DEFAULT_REGION=us-east-1        # AWS region where your S3 bucket lives
S3_BRONZE_BUCKET=                   # S3 bucket name for raw GH Archive data
S3_BRONZE_PREFIX=github-archive/    # Key prefix inside the bronze bucket

# ── Databricks ────────────────────────────────────────────────────────────────
DATABRICKS_HOST=                    # Workspace URL e.g. https://adb-<id>.azuredatabricks.net
DATABRICKS_TOKEN=                   # Personal access token (dapi...)
DATABRICKS_CLUSTER_ID=              # Cluster ID used for interactive / dbt runs
DATABRICKS_HTTP_PATH=               # SQL warehouse HTTP path for dbt-databricks
DATABRICKS_CATALOG=                 # Unity Catalog name (e.g. oss_risk)
DATABRICKS_SCHEMA=                  # Default schema / database (e.g. gold)

# ── dbt ───────────────────────────────────────────────────────────────────────
DBT_PROFILES_DIR=./transformation/dbt  # Path to dbt profiles.yml directory
DBT_TARGET=dev                         # dbt target environment (dev | prod)

# ── Pinecone (Vector Database) ────────────────────────────────────────────────
PINECONE_API_KEY=                   # Pinecone API key
PINECONE_INDEX_NAME=                # Name of your Pinecone index (e.g. dep-risk-index)
PINECONE_NAMESPACE=                 # Namespace within the index (e.g. oss-deps)
PINECONE_ENVIRONMENT=               # Cloud + region slug e.g. us-east-1-aws (serverless: leave blank)

# ── GitHub (API access for supplemental metadata) ─────────────────────────────
GITHUB_TOKEN=                       # GitHub Personal Access Token (read:repo scope)
GITHUB_ARCHIVE_BASE_URL=https://data.gharchive.org  # GH Archive hourly dump URL base

# ── LangGraph / Agent ─────────────────────────────────────────────────────────
LANGGRAPH_RECURSION_LIMIT=50        # Max graph recursion steps before abort
AGENT_MAX_RETRIES=3                 # Number of tool-call retries on transient errors
RISK_SCORE_THRESHOLD=0.65           # Float 0-1; scores above this trigger an alert

# ── Streamlit Frontend ────────────────────────────────────────────────────────
STREAMLIT_SERVER_PORT=8501          # Port the Streamlit app listens on
STREAMLIT_SERVER_ADDRESS=localhost  # Bind address for the dev server

# ── General Application ───────────────────────────────────────────────────────
ENV=development                     # Runtime environment: development | staging | production
LOG_LEVEL=INFO                      # Logging verbosity: DEBUG | INFO | WARNING | ERROR

GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\your\bq-key.json
BIGQUERY_PROJECT_ID=oss-risk-agent