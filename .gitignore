# =============================================================================
# OSS Dependency Risk Agent — .gitignore
# =============================================================================

# ── Secrets & Environment ─────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
secrets/

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
.eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
MANIFEST

# ── Virtual Environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.conda/

# ── Testing & Coverage ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/
.nox/

# ── Type Checking ─────────────────────────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json

# ── dbt ───────────────────────────────────────────────────────────────────────
transformation/dbt/target/
transformation/dbt/dbt_packages/
transformation/dbt/logs/
transformation/dbt/profiles.yml      # Contains credentials — use .env instead

# ── Databricks ────────────────────────────────────────────────────────────────
.databricks/
databricks.yml.local

# ── Spark / PySpark ───────────────────────────────────────────────────────────
derby.log
metastore_db/
spark-warehouse/

# ── Data Files ────────────────────────────────────────────────────────────────
*.parquet
*.csv
*.json.gz
*.ndjson
data/
local_data/

# ── Notebooks ─────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Streamlit ─────────────────────────────────────────────────────────────────
.streamlit/secrets.toml

# ── IDEs & Editors ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
ehthumbs.db
Desktop.ini

# ── Pre-commit ────────────────────────────────────────────────────────────────
.pre-commit-cache/
